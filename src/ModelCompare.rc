/////////////////////////////////////////////////////////////////////////////
// XML Viewer Dialog
//
IDD_XMLVIEWER_DIALOG DIALOGEX 0, 0, 500, 400
STYLE DS_SHELLFONT | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | WS_MAXIMIZEBOX
CAPTION "XML Viewer"
FONT 9, "Consolas", 400, 0, 0x0
