// Microsoft Visual C++ generated resource script.
#include "resource.h"

#define APSTUDIO_READONLY_SYMBOLS
#include "afxres.h"
#undef APSTUDIO_READONLY_SYMBOLS

/////////////////////////////////////////////////////////////////////////////
// Main Dialog — Compact top, two-panel bottom
//
IDD_MODELCOMPARE_DIALOG DIALOGEX 0, 0, 560, 380
STYLE DS_SHELLFONT | WS_MINIMIZEBOX | WS_MAXIMIZEBOX | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "LAI Model Compare Tool"
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    LTEXT           "Left Model (Reference):", IDC_STATIC_LEFT_LABEL, 8, 10, 120, 10
    EDITTEXT        IDC_EDIT_LEFT_PATH, 132, 8, 300, 14, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "Browse...", IDC_BTN_BROWSE_LEFT, 436, 7, 50, 16

    LTEXT           "Right Model (Target):", IDC_STATIC_RIGHT_LABEL, 8, 28, 120, 10
    EDITTEXT        IDC_EDIT_RIGHT_PATH, 132, 26, 300, 14, ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "Browse...", IDC_BTN_BROWSE_RIGHT, 436, 25, 50, 16

    PUSHBUTTON      "Compare\nModels", IDC_BTN_COMPARE, 492, 7, 60, 34, BS_MULTILINE

    LTEXT           "Select two model folders and click Compare.", IDC_STATIC_SUMMARY, 8, 48, 544, 10

    CONTROL         "", IDC_TAB_MAIN, "SysTabControl32", WS_TABSTOP, 8, 62, 544, 310
END

/////////////////////////////////////////////////////////////////////////////
// Spec ID Compare Dialog
//
IDD_TAB_SPEC_ID_COMPARE DIALOGEX 0, 0, 540, 290
STYLE DS_SHELLFONT | DS_CONTROL | WS_CHILD
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    LTEXT           "Diff Files", IDC_STATIC_FILES_HEADER, 0, 0, 130, 10
    CONTROL         "", IDC_LIST_FILES, "SysListView32", LVS_REPORT | LVS_SINGLESEL | LVS_SHOWSELALWAYS | LVS_NOCOLUMNHEADER | WS_BORDER | WS_TABSTOP, 0, 14, 130, 276

    LTEXT           "ID Mismatches", IDC_STATIC_MISMATCH_HEADER, 137, 0, 403, 10
    PUSHBUTTON      "Apply Selection", IDC_BTN_APPLY_SELECTION, 137, 14, 100, 16
    PUSHBUTTON      "Apply All to Right", IDC_BTN_APPLY_ALL, 241, 14, 100, 16
    PUSHBUTTON      "View in XML", IDC_BTN_VIEW_XML, 345, 14, 70, 16
    PUSHBUTTON      "", IDC_BTN_FILE_ACTION, 0, 0, 10, 10, NOT WS_VISIBLE
    CONTROL         "", IDC_LIST_MISMATCHES, "SysListView32", LVS_REPORT | LVS_SHOWSELALWAYS | WS_BORDER | WS_TABSTOP, 137, 34, 403, 256
END

